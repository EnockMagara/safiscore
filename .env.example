PORT=5002
NODE_ENV=development

# MongoDB (use "mongo" for Docker, "localhost" for local dev)
MONGODB_URI=mongodb://mongo:27017/safipoints

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_EXPIRES_IN=7d

# XRPL Testnet
XRPL_NETWORK=wss://s.altnet.rippletest.net:51233

# Platform issuer wallet (auto-generated on first run if empty)
XRPL_ISSUER_ADDRESS=
XRPL_ISSUER_SEED=

# AES-256 encryption key for wallet seeds in DB (exactly 32 chars)
ENCRYPTION_KEY=change_me_32_chars_exactly_here_!

# SAFI token config
SAFI_CURRENCY_CODE=SAFI
SAFI_DEFAULT_EARN_RATE=0.10
SAFI_MIN_REDEMPTION=50
SAFI_REDEMPTION_RATE=0.10

# SafiSend webhook integration
SAFISEND_WEBHOOK_SECRET=shared_webhook_signing_secret
SAFISEND_API_URL=http://localhost:5001

# Client URL — used for CORS in production
CLIENT_URL=https://safipoints.com

# Claim page: any 6-digit code works (set false for strict SMS OTP in production)
# When unset, prototype mode follows NODE_ENV=development
CLAIM_PROTOTYPE_ANY_OTP=true
